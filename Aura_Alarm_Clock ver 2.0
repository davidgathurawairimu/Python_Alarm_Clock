import tkinter as tk
from tkinter import messagebox
import datetime
import time
import threading
import winsound

class AlarmClock:
    def __init__(self, root):
        self.root = root
        self.root.title("Python Alarm Clock")
        self.root.geometry("480x500")
        self.root.resizable(False, False)

        tk.Label(root, text="Set Alarm (24h format)", font=("Algerian", 12, "bold")).pack(pady=10)

        input_frame = tk.Frame(root)
        input_frame.pack(pady=5)

        self.hour = tk.StringVar(value="00")
        self.minute = tk.StringVar(value="00")
        self.second = tk.StringVar(value="00")

        self._create_entry(input_frame, self.hour).pack(side=tk.LEFT)
        tk.Label(input_frame, text=":", font=("Arial", 18)).pack(side=tk.LEFT)
        self._create_entry(input_frame, self.minute).pack(side=tk.LEFT)
        tk.Label(input_frame, text=":", font=("Arial", 18)).pack(side=tk.LEFT)
        self._create_entry(input_frame, self.second).pack(side=tk.LEFT)

        self.set_button = tk.Button(root, text="Set Alarm", command=self.start_alarm_thread, 
                                    bg="#4CAF50", fg="white", font=("Arial", 10, "bold"), width=15)
        self.set_button.pack(pady=20)

    def _create_entry(self, parent, variable):
        return tk.Entry(parent, textvariable=variable, width=3, font=("Arial", 18), justify='center')

    def start_alarm_thread(self):
        alarm_time = f"{self.hour.get().zfill(2)}:{self.minute.get().zfill(2)}:{self.second.get().zfill(2)}"
        self.set_button.config(state=tk.DISABLED, text="Alarm Set...")
        threading.Thread(target=self.run_alarm, args=(alarm_time,), daemon=True).start()

    def run_alarm(self, alarm_time):
        while True:
            current_time = datetime.datetime.now().strftime("%H:%M:%S")
            if current_time == alarm_time:
                self.trigger_alarm() 
                break
            time.sleep(1)

    def trigger_alarm(self):
        # Play Windows system beep (Frequency, Duration in ms)
        for _ in range(5):
            winsound.Beep(1000, 500)
        
        messagebox.showinfo("Alarm", f"Time is {datetime.datetime.now().strftime('%H:%M:%S')}!")
        self.set_button.config(state=tk.NORMAL, text="Set Alarm")

if __name__ == "__main__":
    root = tk.Tk()
    app = AlarmClock(root)
    root.mainloop()
